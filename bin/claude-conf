#!/bin/bash
# ── claude-conf CLI ──────────────────────────────────────────────
# Manage your Claude Code configuration modules
#
# Usage:
#   claude-conf update          Check and apply updates
#   claude-conf status          Show installed/available modules
#   claude-conf install <mod>   Install a specific module
#   claude-conf check           Quick update check (used by cc functions)

set -e

BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ── Find claude-conf repo ────────────────────────────────────────

CONF_DIR=""
if [ -f "$HOME/.claude-conf-path" ]; then
    CONF_DIR=$(cat "$HOME/.claude-conf-path")
fi
if [ -z "$CONF_DIR" ] || [ ! -d "$CONF_DIR/.git" ]; then
    # Try common locations
    for dir in "$HOME/Dev/claude-conf" "$HOME/claude-conf" "$HOME/.claude-conf"; do
        if [ -d "$dir/.git" ]; then
            CONF_DIR="$dir"
            echo "$CONF_DIR" > "$HOME/.claude-conf-path"
            break
        fi
    done
fi

if [ -z "$CONF_DIR" ]; then
    echo -e "${RED}claude-conf repo not found.${NC}"
    echo "Clone it first: git clone https://github.com/Bidiche49/claude-conf.git"
    exit 1
fi

INSTALLED_FILE="$CONF_DIR/.installed"
LAST_CHECK_FILE="$HOME/.claude-conf-last-check"

# ── Helpers ───────────────────────────────────────────────────────

all_modules() {
    find "$CONF_DIR" -maxdepth 2 -name "install.sh" -not -path "$CONF_DIR/install.sh" | while read f; do
        basename "$(dirname "$f")"
    done | sort
}

installed_modules() {
    if [ -f "$INSTALLED_FILE" ]; then
        cat "$INSTALLED_FILE" | sort
    fi
}

is_installed() {
    grep -q "^$1$" "$INSTALLED_FILE" 2>/dev/null
}

mark_installed() {
    if ! is_installed "$1"; then
        echo "$1" >> "$INSTALLED_FILE"
    fi
}

# ── Commands ──────────────────────────────────────────────────────

cmd_check() {
    # Quick silent check — called by cc functions
    # Only check once per day
    local now=$(date +%s)
    local last=0
    if [ -f "$LAST_CHECK_FILE" ]; then
        last=$(cat "$LAST_CHECK_FILE")
    fi
    local diff=$((now - last))

    # Skip if checked less than 24h ago
    if [ "$diff" -lt 86400 ]; then
        return 0
    fi

    # Fetch silently (timeout 3s to not block)
    git -C "$CONF_DIR" fetch --quiet 2>/dev/null &
    local fetch_pid=$!
    sleep 0.5
    if kill -0 "$fetch_pid" 2>/dev/null; then
        # Still fetching after 0.5s, kill it and skip
        kill "$fetch_pid" 2>/dev/null
        wait "$fetch_pid" 2>/dev/null
        return 0
    fi
    wait "$fetch_pid" 2>/dev/null

    echo "$now" > "$LAST_CHECK_FILE"

    # Compare
    local local_head=$(git -C "$CONF_DIR" rev-parse HEAD 2>/dev/null)
    local remote_head=$(git -C "$CONF_DIR" rev-parse origin/main 2>/dev/null)

    if [ "$local_head" != "$remote_head" ]; then
        local count=$(git -C "$CONF_DIR" rev-list HEAD..origin/main --count 2>/dev/null)
        echo -e "${YELLOW}[claude-conf]${NC} ${count} update(s) available. Run ${BOLD}claude-conf update${NC}"
    fi
}

cmd_update() {
    echo -e "${BLUE}${BOLD}claude-conf update${NC}"
    echo ""

    # Fetch
    echo -e "${DIM}Fetching...${NC}"
    git -C "$CONF_DIR" fetch --quiet 2>/dev/null

    local local_head=$(git -C "$CONF_DIR" rev-parse HEAD)
    local remote_head=$(git -C "$CONF_DIR" rev-parse origin/main)

    if [ "$local_head" = "$remote_head" ]; then
        echo -e "${GREEN}Already up to date.${NC}"
        echo "$( date +%s)" > "$LAST_CHECK_FILE"
        return 0
    fi

    # Show what changed
    local count=$(git -C "$CONF_DIR" rev-list HEAD..origin/main --count)
    echo -e "${YELLOW}${count} new commit(s):${NC}"
    echo ""
    git -C "$CONF_DIR" log HEAD..origin/main --oneline --no-decorate | while read line; do
        echo -e "  ${DIM}•${NC} $line"
    done
    echo ""

    # Check for new modules
    local new_modules=$(git -C "$CONF_DIR" diff HEAD..origin/main --name-only | grep "install.sh" | grep -v "^install.sh$" | sed 's|/install.sh||' | sort -u)
    if [ -n "$new_modules" ]; then
        echo -e "${GREEN}${BOLD}New/updated modules:${NC}"
        for mod in $new_modules; do
            if is_installed "$mod"; then
                echo -e "  ${BLUE}↑${NC} ${mod} ${DIM}(installed — will be updated)${NC}"
            else
                echo -e "  ${GREEN}+${NC} ${mod} ${DIM}(new — install with: claude-conf install ${mod})${NC}"
            fi
        done
        echo ""
    fi

    # Ask
    echo -ne "Apply update? ${BOLD}[Y/n]${NC} "
    read -r answer
    if [ "$answer" = "n" ] || [ "$answer" = "N" ]; then
        echo -e "${DIM}Skipped.${NC}"
        return 0
    fi

    # Pull
    git -C "$CONF_DIR" pull --quiet origin main

    # Reinstall updated modules
    local updated=0
    if [ -n "$new_modules" ]; then
        for mod in $new_modules; do
            if is_installed "$mod"; then
                echo -e "${BLUE}Updating ${mod}...${NC}"
                bash "$CONF_DIR/$mod/install.sh"
                updated=$((updated + 1))
            fi
        done
    fi

    echo ""
    if [ "$updated" -gt 0 ]; then
        echo -e "${GREEN}Updated ${updated} module(s). Restart Claude Code for changes to take effect.${NC}"
    else
        echo -e "${GREEN}Repo updated.${NC}"
    fi

    echo "$(date +%s)" > "$LAST_CHECK_FILE"
}

cmd_status() {
    echo -e "${BLUE}${BOLD}claude-conf status${NC}"
    echo ""

    local all=$(all_modules)
    local inst=$(installed_modules)

    echo -e "${BOLD}Modules:${NC}"
    echo ""
    for mod in $all; do
        if is_installed "$mod"; then
            echo -e "  ${GREEN}●${NC} ${mod} ${DIM}(installed)${NC}"
        else
            echo -e "  ${DIM}○${NC} ${mod}"
        fi
    done
    echo ""

    local total=$(echo "$all" | wc -l | tr -d ' ')
    local installed_count=0
    if [ -n "$inst" ]; then
        installed_count=$(echo "$inst" | wc -l | tr -d ' ')
    fi
    echo -e "${DIM}${installed_count}/${total} modules installed${NC}"
}

cmd_install() {
    local mod="$1"
    if [ -z "$mod" ]; then
        echo -e "${RED}Usage: claude-conf install <module>${NC}"
        echo ""
        echo "Available modules:"
        all_modules | while read m; do
            echo "  $m"
        done
        return 1
    fi

    if [ ! -f "$CONF_DIR/$mod/install.sh" ]; then
        echo -e "${RED}Module '${mod}' not found.${NC}"
        return 1
    fi

    echo -e "${BLUE}Installing ${mod}...${NC}"
    bash "$CONF_DIR/$mod/install.sh"
    mark_installed "$mod"
    echo ""
    echo -e "${GREEN}${mod} installed and tracked.${NC}"
}

cmd_sync() {
    echo -e "${BLUE}${BOLD}claude-conf sync${NC}"
    echo ""

    # Map: module → list of (repo_path, local_path) pairs
    local desync=0
    local checked=0

    for mod in $(installed_modules); do
        local mod_dir="$CONF_DIR/$mod"
        [ ! -d "$mod_dir" ] && continue

        # Find all installable files and their local destinations
        case "$mod" in
            tab-titles)
                _sync_file "$mod" "hooks/tab-title.sh" "$HOME/.claude/hooks/tab-title.sh"
                ;;
            handoff-kit)
                _sync_file "$mod" "hooks/context-monitor.sh" "$HOME/.claude/hooks/context-monitor.sh"
                _sync_file "$mod" "hooks/pre-compact-handoff.sh" "$HOME/.claude/hooks/pre-compact-handoff.sh"
                _sync_file "$mod" "commands/handoff.md" "$HOME/.claude/commands/handoff.md"
                ;;
            supervisor)
                _sync_file "$mod" "commands/supervisor.md" "$HOME/.claude/commands/supervisor.md"
                ;;
            command-guard)
                _sync_file "$mod" "src/cli.ts" "$HOME/.claude/scripts/command-guard/src/cli.ts"
                _sync_file "$mod" "src/lib/validator.ts" "$HOME/.claude/scripts/command-guard/src/lib/validator.ts"
                _sync_file "$mod" "src/lib/types.ts" "$HOME/.claude/scripts/command-guard/src/lib/types.ts"
                ;;
        esac
    done

    if [ "$SYNC_DESYNC" -eq 0 ]; then
        echo -e "${GREEN}All installed modules are in sync.${NC}"
    else
        echo ""
        echo -e "${YELLOW}${SYNC_DESYNC} file(s) out of sync.${NC}"
        echo -e "${DIM}Run 'claude-conf sync --fix' to copy repo → local${NC}"
        echo -e "${DIM}Or manually update the repo to match your local changes.${NC}"
    fi
}

SYNC_DESYNC=0

_sync_file() {
    local mod="$1"
    local repo_rel="$2"
    local local_path="$3"
    local repo_path="$CONF_DIR/$mod/$repo_rel"

    if [ ! -f "$repo_path" ]; then
        return 0
    fi

    if [ ! -f "$local_path" ]; then
        echo -e "  ${RED}MISSING${NC} ${mod}/${repo_rel}"
        echo -e "    ${DIM}Not installed locally: ${local_path}${NC}"
        SYNC_DESYNC=$((SYNC_DESYNC + 1))
        return 0
    fi

    if ! diff -q "$repo_path" "$local_path" &>/dev/null; then
        echo -e "  ${YELLOW}DESYNC${NC}  ${mod}/${repo_rel}"
        echo -e "    ${DIM}repo:  ${repo_path}${NC}"
        echo -e "    ${DIM}local: ${local_path}${NC}"

        if [ "$FIX_MODE" = "1" ]; then
            cp "$repo_path" "$local_path"
            echo -e "    ${GREEN}→ Fixed (repo → local)${NC}"
        else
            # Show brief diff summary
            local lines=$(diff "$repo_path" "$local_path" | grep -c '^[<>]' 2>/dev/null || echo "?")
            echo -e "    ${DIM}${lines} line(s) differ${NC}"
        fi

        SYNC_DESYNC=$((SYNC_DESYNC + 1))
    fi
}

cmd_sync_fix() {
    FIX_MODE=1
    cmd_sync
}

cmd_help() {
    echo -e "${BOLD}claude-conf${NC} — Manage your Claude Code configuration"
    echo ""
    echo "Commands:"
    echo "  update              Check and apply updates"
    echo "  status              Show installed/available modules"
    echo "  install <module>    Install a specific module"
    echo "  sync                Check local files match repo"
    echo "  sync --fix          Fix desyncs (repo → local)"
    echo "  check               Quick update check (used internally)"
    echo "  help                Show this help"
    echo ""
    echo "Repo: https://github.com/Bidiche49/claude-conf"
}

# ── Main ──────────────────────────────────────────────────────────

case "${1:-help}" in
    update)     cmd_update ;;
    status)     cmd_status ;;
    install)    cmd_install "$2" ;;
    sync)
        if [ "$2" = "--fix" ]; then
            cmd_sync_fix
        else
            cmd_sync
        fi
        ;;
    check)      cmd_check ;;
    help)       cmd_help ;;
    *)          echo -e "${RED}Unknown command: $1${NC}"; cmd_help; exit 1 ;;
esac
